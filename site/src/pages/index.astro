---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getColumns, getHomeFeaturedOrder, getPublishedPosts, sortByNewest } from "../lib/content";

const posts = await getPublishedPosts();
const columns = await getColumns();
const featuredOrder = await getHomeFeaturedOrder();
const newestPosts = sortByNewest(posts);
const postBySlug = new Map(posts.map((post) => [post.slug, post]));
const featuredPosts = featuredOrder.map((slug) => postBySlug.get(slug)).filter(Boolean);
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="文章 / 个人博客" active="posts">
  <div class="section-heading">
    <h1 data-view-title>最新文章</h1>
    <div class="segmented" data-view-toggle>
      <a href={base} class="active" data-view-link="newest">最新</a>
      <a href={`${base}?sort=featured`} data-view-link="featured">推荐</a>
    </div>
  </div>
  <div data-view-panel="newest">
    <PostList posts={newestPosts} columns={columns} />
  </div>
  <div data-view-panel="featured" hidden>
    {featuredPosts.length > 0
      ? <PostList posts={featuredPosts} columns={columns} />
      : <p class="empty-state">暂无推荐文章。</p>}
  </div>
  <script>
    const title = document.querySelector("[data-view-title]");
    const links = [...document.querySelectorAll("[data-view-link]")];
    const panels = [...document.querySelectorAll("[data-view-panel]")];

    function setView(view, push = false) {
      const next = view === "featured" ? "featured" : "newest";
      if (title) title.textContent = next === "featured" ? "推荐文章" : "最新文章";
      links.forEach((link) => link.classList.toggle("active", link.dataset.viewLink === next));
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.viewPanel !== next;
      });
      if (push) {
        const url = next === "featured" ? `${location.pathname}?sort=featured` : location.pathname;
        history.pushState({}, "", url);
      }
    }

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        setView(link.dataset.viewLink, true);
      });
    });

    setView(new URLSearchParams(location.search).get("sort"));
    window.addEventListener("popstate", () => setView(new URLSearchParams(location.search).get("sort")));
  </script>
</BaseLayout>
