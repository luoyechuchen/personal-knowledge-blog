---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getColumns, getHomeFeaturedOrder, getPublishedPosts, sortByNewest } from "../lib/content";

const sort = Astro.url.searchParams.get("sort") === "featured" ? "featured" : "newest";
const posts = await getPublishedPosts();
const columns = await getColumns();
const featuredOrder = await getHomeFeaturedOrder();
const newestPosts = sortByNewest(posts);
const postBySlug = new Map(posts.map((post) => [post.slug, post]));
const featuredPosts = featuredOrder.map((slug) => postBySlug.get(slug)).filter(Boolean);
const featuredSet = new Set(featuredPosts.map((post) => post.slug));
const featuredDisplay = featuredPosts.length > 0
  ? [...featuredPosts, ...newestPosts.filter((post) => !featuredSet.has(post.slug))]
  : newestPosts;
const displayPosts = sort === "featured" ? featuredDisplay : newestPosts;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="文章 / 个人博客" active="posts">
  <div class="section-heading">
    <h1>最新文章</h1>
    <div class="segmented">
      <a href={base} class={sort === "newest" ? "active" : ""}>最新</a>
      <a href={`${base}?sort=featured`} class={sort === "featured" ? "active" : ""}>推荐</a>
    </div>
  </div>
  <PostList posts={displayPosts} columns={columns} />
</BaseLayout>
