---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArchiveItemBySlug, getArchiveItems, getPublishedPosts } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";

export async function getStaticPaths() {
  const items = await getArchiveItems();
  return items
    .filter((item) => item.slug && item.contentMarkdown)
    .map((item) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
const item = await getArchiveItemBySlug(slug ?? "");
const posts = await getPublishedPosts();
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const html = item?.contentMarkdown ? renderMarkdown(item.contentMarkdown, posts, base) : "";
---

<BaseLayout title={`${item?.title ?? "资料"} / 资料存档`} active="archive">
  {item && (
    <article class="article">
      <a class="back-link" href={`${base}archive/`}>返回资料存档</a>
      <h1>{item.title}</h1>
      <div class="meta article-meta">
        {item.author || "佚名"} · {item.source || "本地原文"} · {item.savedAt || "未记录日期"}
      </div>
      {item.note && <p class="article-note">{item.note}</p>}
      <div class="markdown" set:html={html} />
    </article>
  )}
</BaseLayout>
