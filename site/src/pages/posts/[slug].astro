---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getColumnName, getColumns, getPostBySlug, getPublishedPosts } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const posts = await getPublishedPosts();
const post = await getPostBySlug(slug ?? "");
const columns = await getColumns();
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const html = post ? renderMarkdown(post.markdown, posts, base) : "";
const viewCounterConfigPath = `${base}view-counter.json`;
---

<BaseLayout title={`${post?.title ?? "文章"} / 个人博客`} active="posts">
  {post && (
    <article class="article">
      <a class="back-link" href={base}>返回文章</a>
      <h1>{post.title}</h1>
      <div class="meta article-meta">{getColumnName(columns, post.column)} · {post.publishedAt}</div>
      <div class="markdown" set:html={html} />
    </article>
  )}
  {post && (
    <script is:inline define:vars={{ postSlug: post.slug, viewCounterConfigPath }}>
      (() => {
        let reported = false;

        const reportView = async () => {
          if (reported || document.visibilityState !== "visible") return;

          const configResponse = await fetch(`${viewCounterConfigPath}?ts=${Date.now()}`, { cache: "no-store" });
          if (!configResponse.ok) return;
          const config = await configResponse.json();
          const endpoint = config?.endpoint;
          if (!endpoint) return;

          reported = true;
          const payload = JSON.stringify({ slug: postSlug });
          if (navigator.sendBeacon && navigator.sendBeacon(endpoint, payload)) return;

          fetch(endpoint, {
            method: "POST",
            body: payload,
            mode: "cors",
            keepalive: true
          }).catch(() => {});
        };

        if (document.visibilityState === "visible") reportView().catch(() => {});
        else document.addEventListener("visibilitychange", () => reportView().catch(() => {}), { once: true });
      })();
    </script>
  )}
</BaseLayout>
