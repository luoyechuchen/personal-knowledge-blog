---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getColumns, getPublishedPosts, sortByNewest } from "../../lib/content";

const columns = await getColumns();
const posts = await getPublishedPosts();
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="专栏 / 个人博客" active="columns">
  <div class="section-heading">
    <h1>专栏</h1>
  </div>
  <div class="column-list">
    {columns.map((column) => {
      const columnPosts = posts.filter((post) => post.column === column.slug);
      const latest = sortByNewest(columnPosts).at(0)?.publishedAt;
      return (
        <article class="column-item">
          <a href={`${base}columns/${column.slug}/`} class="post-title">{column.name}</a>
          <p>{column.description}</p>
          <div class="meta">{columnPosts.length} 篇文章{latest ? ` · 最后更新 ${formatDate(latest)}` : ""}</div>
        </article>
      );
    })}
  </div>
</BaseLayout>
