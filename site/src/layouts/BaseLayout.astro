---
type Props = {
  title?: string;
  active?: "posts" | "columns" | "archive" | "library" | "search";
};

const { title = "个人博客", active = "posts" } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (href: string) => `${base}${href.replace(/^\//, "")}`;

const navItems = [
  { href: "/", label: "文章", key: "posts" },
  { href: "/columns/", label: "专栏", key: "columns" },
  { href: "/archive/", label: "资料存档", key: "archive" },
  { href: "/library/", label: "图书馆", key: "library" }
];
---

<!doctype html>
<html lang="zh-CN" data-base={base} data-theme="night">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("site-theme");
      document.documentElement.dataset.theme = savedTheme === "day" ? "day" : "night";
    </script>
    <link rel="stylesheet" href={`${withBase("/styles/global.css")}?v=post-admin-1`} />
  </head>
  <body>
    <header class="site-header">
      <a class="identity" href={base}>
        <strong>无边落夜</strong>
        <span>头顶的星空和心中的道德律法，是我所认知的世界，并越发与现实同一</span>
      </a>
      <nav class="top-nav" aria-label="顶部导航">
        <a href={withBase("/search/")} class={active === "search" ? "active" : ""}>搜索</a>
        <a href={withBase("/about/")}>关于</a>
        <button class="theme-toggle" type="button" aria-label="切换日间和夜间模式" data-theme-toggle>日间</button>
      </nav>
    </header>
    <main class="shell">
      <aside class="side-nav" aria-label="内容视图">
        {navItems.map((item) => (
          <a href={withBase(item.href)} class={active === item.key ? "active" : ""}>{item.label}</a>
        ))}
      </aside>
      <section class="content-panel">
        <slot />
      </section>
    </main>
    <script is:inline>
      const toggle = document.querySelector("[data-theme-toggle]");
      const setThemeLabel = () => {
        const current = document.documentElement.dataset.theme;
        if (toggle) toggle.textContent = current === "night" ? "日间" : "夜间";
      };

      setThemeLabel();
      toggle?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "night" ? "day" : "night";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("site-theme", next);
        setThemeLabel();
      });
    </script>
  </body>
</html>
