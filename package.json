{
  "name": "personal-knowledge-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "site",
    "admin"
  ],
  "scripts": {
    "dev:site": "npm --workspace site run dev",
    "build": "npm run generate:search && npm --workspace site run build",
    "preview:site": "npm --workspace site run preview",
    "dev:admin": "npm --workspace admin run dev",
    "start:admin": "npm --workspace admin run start",
    "generate:search": "node scripts/generate-search-index.mjs",
    "validate:content": "node scripts/validate-content.mjs"
  }
}
